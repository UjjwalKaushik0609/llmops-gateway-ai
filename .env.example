# ============================================================
# LLMOps Gateway AI - Environment Configuration
# ============================================================

# App
APP_NAME=LLMOps Gateway AI
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://llmops:llmops_pass@localhost:5432/llmops_db
SYNC_DATABASE_URL=postgresql://llmops:llmops_pass@localhost:5432/llmops_db

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=llmops_memory

# LLM Provider API Keys (encrypted at rest)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
GEMINI_API_KEY=your-gemini-key
MISTRAL_API_KEY=your-mistral-key
GROK_API_KEY=your-grok-key

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-base64

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# AWS (for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=llmops-gateway-ai

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Cost Thresholds
DAILY_COST_THRESHOLD_USD=100.0
MONTHLY_COST_THRESHOLD_USD=2000.0

# Routing Preferences
DEFAULT_PROVIDER=openai
FALLBACK_PROVIDER=anthropic
ENABLE_COST_OPTIMIZATION=true
ENABLE_AUTO_ROUTING=true
