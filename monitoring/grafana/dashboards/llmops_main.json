{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "LLMOps Gateway AI - Real-time Platform Monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Requests (24h)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(llmops_requests_total[24h]))", "legendFormat": "Requests" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Cost Today (USD)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(llmops_cost_usd_total[24h]))", "legendFormat": "Cost" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "currencyUSD", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] } } }
    },
    {
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "title": "Avg Latency (p95)",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(llmops_request_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95 ms" }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5000 }, { "color": "red", "value": 15000 }] } } },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "title": "Security Blocks (1h)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(llmops_security_blocks_total[1h]))", "legendFormat": "Blocks" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 10 }] } } },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "title": "Cache Hit Rate",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(llmops_cache_hits_total[5m])) / (sum(rate(llmops_cache_hits_total[5m])) + sum(rate(llmops_cache_misses_total[5m]))) * 100", "legendFormat": "Hit Rate %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 60 }] } } },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 0 },
      "id": 6,
      "title": "Total Tokens (24h)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(llmops_tokens_total[24h]))", "legendFormat": "Tokens" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "id": 7,
      "title": "Request Rate by Provider",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (provider) (rate(llmops_requests_total[5m]))", "legendFormat": "{{ provider }}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "id": 8,
      "title": "Cost Rate by Provider ($/hour)",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (provider) (rate(llmops_cost_usd_total[5m])) * 3600", "legendFormat": "{{ provider }}" }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 9,
      "title": "Request Latency Distribution (p50/p95/p99)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(llmops_request_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(llmops_request_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(llmops_request_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 10,
      "title": "Error Rate by Provider",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (provider) (rate(llmops_errors_total[5m]))", "legendFormat": "{{ provider }}: {{ error_type }}" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 11,
      "title": "Provider Distribution",
      "type": "piechart",
      "targets": [{ "expr": "sum by (provider) (increase(llmops_requests_total[24h]))", "legendFormat": "{{ provider }}" }]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 12,
      "title": "Routing Strategy Distribution",
      "type": "piechart",
      "targets": [{ "expr": "sum by (routing_strategy) (increase(llmops_requests_total[24h]))", "legendFormat": "{{ routing_strategy }}" }]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 13,
      "title": "Provider Availability",
      "type": "stat",
      "targets": [{ "expr": "llmops_provider_up", "legendFormat": "{{ provider }}" }],
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [] } } },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["llmops", "ai", "mlops"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "LLMOps Gateway AI",
  "uid": "llmops-main-dashboard",
  "version": 1
}
